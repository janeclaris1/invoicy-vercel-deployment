{
  "installCommand": "npm install && npm install --prefix Frontend/Invoicy --include=dev",
  "buildCommand": "cd Frontend/Invoicy && npm run build",
  "outputDirectory": "Frontend/Invoicy/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "Backend/**"
    }
  }
}
